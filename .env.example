# =============================================================================
# Gatehouse — Environment Configuration
# Copy this file to .env and fill in all REQUIRED values before running.
#
# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#   openssl rand -hex 32
# =============================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Flask secret key — must be long, random, and kept secret
SECRET_KEY=change-me-use-openssl-rand-hex-32

# PostgreSQL connection string
DATABASE_URL=postgresql://gatehouse:password@your-db-host:5432/gatehouse

# Encryption keys for sensitive data at rest
ENCRYPTION_KEY=change-me-use-openssl-rand-hex-32
CA_ENCRYPTION_KEY=change-me-use-openssl-rand-hex-32

# ── URLS ──────────────────────────────────────────────────────────────────────

# Public URL where users reach the frontend (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Public URL where the backend is reachable (used for OIDC issuer)
OIDC_ISSUER_URL=http://localhost:5000

# ── WEBAUTHN ──────────────────────────────────────────────────────────────────
# Must match the domain (and port if non-standard) that users see in the browser.

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Gatehouse
WEBAUTHN_ORIGIN=http://localhost:3000

# ── SESSION COOKIES ───────────────────────────────────────────────────────────
# Set SESSION_COOKIE_SECURE=True when serving over HTTPS.
# Set SESSION_COOKIE_SAMESITE=Strict for stricter CSRF protection.

SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax

# ── LOGGING ───────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ── OPTIONAL: deployment branches ────────────────────────────────────────────
# Override which branch is cloned during Docker build.

# BACKEND_BRANCH=main
# FRONTEND_BRANCH=main

# ── OPTIONAL: frontend port ───────────────────────────────────────────────────
# Change if port 3000 is already in use on the host.

# FRONTEND_PORT=3000
